# Copy this file to .env (or .env.local) and fill in real values.
# Never commit the resulting file — see docs/Development/Environment.md.

# Application
NEXT_PUBLIC_APP_NAME="AI Song Campaign Platform"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Supabase
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Database (Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/dbname?schema=public"

# Resend
RESEND_API_KEY="your-resend-api-key"

# Anthropic Claude
CLAUDE_API_KEY="your-claude-api-key"

# Suno
SUNO_API_KEY="your-suno-api-key"

# Admin
ADMIN_EMAIL="admin@example.com"
# Must be a long, random, secret string (32+ chars) — signs admin session
# cookies. Generate with, e.g., `openssl rand -base64 48`.
ADMIN_SESSION_SECRET="replace-with-a-long-random-secret-at-least-32-characters"

# Campaign
CAMPAIGN_NAME="AI Song Campaign"
MAX_LYRIC_ATTEMPTS="5"
CAMPAIGN_MAX_SONGS="3000"
