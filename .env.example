# Copy this file to .env (or .env.local) and fill in real values.
# Never commit the resulting file — see docs/Development/Environment.md.

# Application
NEXT_PUBLIC_APP_NAME="AI Song Campaign Platform"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Supabase
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Database (Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/dbname?schema=public"

# Resend
RESEND_API_KEY="your-resend-api-key"
EMAIL_FROM="onboarding@resend.dev"

# Cloudflare R2 (private bucket — no public access; downloads use signed URLs)
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET="your-r2-bucket-name"

# Anthropic Claude
CLAUDE_API_KEY="your-claude-api-key"

# Suno (the active music provider for V1 — see PROJECT_MANIFEST.md)
SUNO_API_KEY="your-suno-api-key"

# Mureka (built and tested, not wired into the live pipeline — see
# docs/Architecture/External_Services.md)
MUREKA_API_KEY="your-mureka-api-key"

# Admin
ADMIN_EMAIL="admin@example.com"
# Must be a long, random, secret string (32+ chars) — signs admin session
# cookies. Generate with, e.g., `openssl rand -base64 48`.
ADMIN_SESSION_SECRET="replace-with-a-long-random-secret-at-least-32-characters"

# Campaign
CAMPAIGN_NAME="AI Song Campaign"
MAX_LYRIC_ATTEMPTS="5"
CAMPAIGN_MAX_SONGS="3000"

# Song generation pipeline (RC-2 — Production Hardening)
# Minutes a Song may stay GENERATING before GenerationDispatcher reclaims
# it (marks it FAILED, freeing the one-concurrent-generation slot).
# Optional — defaults to 30.
GENERATION_TIMEOUT_MINUTES="30"

# Internal operations (RC-2 — Production Hardening)
# Shared secret protecting every /api/internal/* endpoint (the Vercel
# Cron pipeline tick and the operational health check). Must be a long,
# random, secret string (32+ chars) — generate the same way as
# ADMIN_SESSION_SECRET. When this project is deployed on Vercel with a
# CRON_SECRET environment variable set, Vercel Cron automatically sends
# it as the Authorization header on every scheduled invocation — no
# extra configuration needed.
CRON_SECRET="replace-with-a-long-random-secret-at-least-32-characters"

# Cloudflare Turnstile (Sprint 8.2 — Abuse Protection)
# The defaults below are Cloudflare's publicly documented "always
# passes" test keypair — safe for local dev, but production MUST
# override both with real site/secret keys from the Cloudflare
# dashboard. Optional locally; required in production.
TURNSTILE_SECRET_KEY="1x0000000000000000000000000000000AA"
NEXT_PUBLIC_TURNSTILE_SITE_KEY="1x00000000000000000000AA"

# Rate limiting (Sprint 8.2 — Abuse Protection). All optional — every
# value below is the built-in default; only set one to override it.
RATE_LIMIT_WINDOW_MINUTES="60"
MAX_REGISTRATIONS_PER_IP="5"
MAX_REGISTRATIONS_PER_EMAIL="3"
MAX_GENERATIONS_PER_HOUR="10"
MAX_GENERATIONS_PER_IP_PER_HOUR="20"
MAX_APPROVALS_PER_HOUR="10"
MAX_SESSION_REQUESTS_PER_WINDOW="30"
SESSION_RATE_LIMIT_WINDOW_MINUTES="1"
# RC-2 — Production Hardening: rate limiting for POST /api/admin/login,
# the same abuse-protection treatment every public endpoint already has.
MAX_ADMIN_LOGIN_ATTEMPTS_PER_WINDOW="10"
