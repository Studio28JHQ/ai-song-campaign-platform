// Prisma schema for the AI Song Campaign Platform.
// See docs/Architecture/Database_Model.md for entity documentation,
// relationships, constraints, and the reasoning behind them.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED

  @@map("campaign_status")
}

enum LeadStatus {
  REGISTERED
  MODERATION_REJECTED
  LYRICS_GENERATED
  LYRICS_APPROVED
  SONG_GENERATING
  SONG_READY
  COMPLETED
  ATTEMPTS_EXHAUSTED

  @@map("lead_status")
}

enum GenerationAttemptResult {
  SUCCESS
  MODERATION_REJECTED
  FAILED

  @@map("generation_attempt_result")
}

// QUEUED / GENERATING / COMPLETED / FAILED are the only valid generation
// states as of Sprint 7.5 (see PROJECT_MANIFEST.md — Architecture
// exception). `DELIVERED` remains reserved for a future email-delivery
// module (not implemented) and still collapses to `COMPLETED` on read —
// see `SongMapper`.
enum SongStatus {
  QUEUED
  GENERATING
  COMPLETED
  DELIVERED
  FAILED

  @@map("song_status")
}

// Sprint v1.1 — AI Musical Direction. The parent's requested narrator
// voice for the song, selected on the lyrics generation form and
// carried through to the Mureka prompt only (see `Lyrics.voice`) —
// never sent to Claude, never affects lyrics generation.
enum Voice {
  FEMALE
  MALE

  @@map("voice")
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model Campaign {
  id                  String         @id @default(uuid()) @db.Uuid
  name                String
  status              CampaignStatus @default(DRAFT)
  maximumSongs        Int
  songsGenerated      Int            @default(0)
  startsAt            DateTime
  endsAt              DateTime
  isGenerationEnabled Boolean        @default(true)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  leads Lead[]

  @@index([status])
  @@map("campaigns")
}

model Lead {
  id                String     @id @default(uuid()) @db.Uuid
  campaignId        String     @db.Uuid
  parentName        String
  babyName          String
  babyAge           Int?
  city              String?
  email             String     @unique
  phone             String?
  remainingAttempts Int        @default(5)
  status            LeadStatus @default(REGISTERED)
  // "Resume journey by email" — a stable, cryptographically random token
  // for the emailed resume link (see `ResolveResumeTokenUseCase`).
  // Generated once at registration and never rotated; unrelated to
  // `LeadSession.token`, which is short-lived/reissuable per session.
  resumeToken       String     @unique
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  campaign           Campaign            @relation(fields: [campaignId], references: [id], onDelete: Restrict)
  lyrics             Lyrics[]
  song               Song?
  generationAttempts GenerationAttempt[]
  sessions           LeadSession[]

  @@index([campaignId])
  @@index([status])
  @@index([createdAt])
  @@map("leads")
}

// A dedicated, opaque, DB-backed session token for the parent-facing flow
// (registration -> lyrics -> song) — deliberately separate from Lead
// itself (a session is an auth concern, not a Lead attribute) and from
// the Admin module's stateless, signed session token (this one must be
// revocable/lookupable, per GATE 6.6). The browser only ever holds the
// opaque `token`, never `leadId`.
model LeadSession {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique
  leadId    String   @db.Uuid
  expiresAt DateTime
  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("lead_sessions")
}

model Mood {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @unique
  description  String?
  sunoPrompt   String
  displayOrder Int      @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lyrics Lyrics[]
  songs  Song[]

  @@index([active])
  @@map("moods")
}

model Lyrics {
  id              String   @id @default(uuid()) @db.Uuid
  leadId          String   @db.Uuid
  moodId          String   @db.Uuid
  prompt          String
  content         String
  // Sprint v1.1 — AI Musical Direction. `parentMessage` is the parent's
  // own song description (the "Baby Context" the Mureka prompt is built
  // from at song-generation time); `musicMood`/`musicDirection` are
  // Claude's own creative interpretation, generated alongside the lyrics
  // in the same call — see `PromptBuilder`/`ResponseParser` (Claude).
  // Nullable so pre-existing Lyrics rows (created before this migration)
  // remain valid; every row created going forward always sets all three,
  // enforced by `Lyrics.create`. `voice` has a safe default for the same
  // backward-compatibility reason.
  parentMessage   String?
  musicMood       String?
  musicDirection  String?
  voice           Voice    @default(FEMALE)
  approved        Boolean  @default(false)
  rejectionReason String?
  version         Int
  createdAt       DateTime @default(now())

  lead              Lead               @relation(fields: [leadId], references: [id], onDelete: Cascade)
  mood              Mood               @relation(fields: [moodId], references: [id], onDelete: Restrict)
  generationAttempt GenerationAttempt?
  songs             Song[]

  @@unique([leadId, version])
  @@index([leadId])
  @@index([approved])
  @@map("lyrics")
}

model GenerationAttempt {
  id            String                  @id @default(uuid()) @db.Uuid
  leadId        String                  @db.Uuid
  lyricsId      String?                 @unique @db.Uuid
  attemptNumber Int
  result        GenerationAttemptResult
  failureReason String?
  createdAt     DateTime                @default(now())

  lead   Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  lyrics Lyrics? @relation(fields: [lyricsId], references: [id], onDelete: SetNull)

  @@unique([leadId, attemptNumber])
  @@index([leadId])
  @@index([result])
  @@index([createdAt])
  @@map("generation_attempts")
}

// Sprint 9.1 — Generation Pipeline Refinement. Provider interaction is
// split into a submit phase (GenerationDispatcher) and a poll phase
// (GenerationPoller); these columns are what lets the poller resume
// tracking a song across separate invocations. `audioStorageKey` is the
// *only* durable reference to the generated audio — a Cloudflare R2
// object key, never a signed URL or a provider URL (both expire and
// must never be persisted; see `AudioUrlResolver`, resolved fresh at
// read time). `providerStatus`/`providerError` mirror the provider's own
// last-reported state for diagnostics; `submittedAt`/`completedAt`
// bound how long a generation was in flight.
model Song {
  id              String     @id @default(uuid()) @db.Uuid
  leadId          String     @unique @db.Uuid
  lyricsId        String     @db.Uuid
  moodId          String     @db.Uuid
  provider        String     @default("suno")
  providerSongId  String?
  providerTaskId  String?
  providerTraceId String?
  providerStatus  String?
  providerError   String?
  audioStorageKey String?
  duration        Int?
  status          SongStatus @default(QUEUED)
  submittedAt     DateTime?
  generatedAt     DateTime?
  completedAt     DateTime?
  emailedAt       DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  lyrics Lyrics @relation(fields: [lyricsId], references: [id], onDelete: Restrict)
  mood   Mood   @relation(fields: [moodId], references: [id], onDelete: Restrict)

  @@index([status])
  @@index([createdAt])
  @@index([providerTaskId])
  @@map("songs")
}

model AdminUser {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  passwordHash String
  name         String
  role         String    @default("admin")
  active       Boolean   @default(true)
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  auditLogs AuditLog[]

  @@map("admin_users")
}

// `adminId` is nullable as of Sprint 8.2 (Abuse Protection): a `null`
// actor represents a system-recorded security/abuse event (rate limit
// exceeded, invalid Turnstile token, ...) rather than an admin action —
// see `docs/Architecture/System_Architecture.md`. Every pre-existing
// admin-initiated entry still always sets `adminId`.
model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  adminId   String?  @db.Uuid
  action    String
  entity    String
  entityId  String?  @db.Uuid
  metadata  Json?
  createdAt DateTime @default(now())

  admin AdminUser? @relation(fields: [adminId], references: [id], onDelete: Restrict)

  @@index([adminId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// Sprint 8.2 — Abuse Protection. A generic, DB-backed sliding-window
// rate-limit event log: one row per consumed request, keyed by scope
// (e.g. "registration:ip:1.2.3.4"). No Redis/queue — see
// PROJECT_MANIFEST.md. Counting recent rows for a key within a window
// is the entire mechanism; see `RateLimitRepository`.
model RateLimitEvent {
  id        String   @id @default(uuid()) @db.Uuid
  key       String
  createdAt DateTime @default(now())

  @@index([key, createdAt])
  @@map("rate_limit_events")
}
